{
  "manifest_version": 3,
  "name": "ShipSnap",
  "version": "1.0.0",
  "description": "Turn your GitHub PRs into beautiful, shareable cards — with stats, themes & one-click social sharing. Build your personal brand as a developer.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://avatars.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "ShipSnap – Share your PR",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["generator.html", "generator.css", "generator.js", "html-to-image.min.js"],
      "matches": ["https://github.com/*"]
    }
  ]
}
